{
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "eslint": "^9.39.1",
    "husky": "^8.0.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "prepare": "husky install",
    "type-check": "npm run --prefix frontend type-check"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx}": "eslint -c frontend/eslint.config.js --fix",
    "backend/src/**/*.js": "prettier --write"
  }
}
